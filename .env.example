# Copy to .env.local and fill in real values. Never commit .env.local.

# Site
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_SITE_NAME=oandilabel
APP_BASE_URL=https://your-domain.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=O & I Label <noreply@your-domain.com>
ADMIN_EMAIL=admin@your-domain.com
EMAIL_FROM=noreply@your-domain.com
NEWSLETTER_WELCOME_EMAIL=1

# Moolre payments (aliases supported: MOOLRE_MERCHANT_EMAIL, MOOLRE_CALLBACK_SECRET)
MOOLRE_API_USER=
MOOLRE_API_PUBKEY=
MOOLRE_ACCOUNT_NUMBER=
MOOLRE_BUSINESS_EMAIL=
MOOLRE_MERCHANT_EMAIL=
MOOLRE_WEBHOOK_SECRET=
MOOLRE_CALLBACK_SECRET=
MOOLRE_REUSABLE=0

# Moolre SMS (aliases: MOOLRE_SMS_API_KEY, SMS_SENDER_ID)
MOOLRE_SMS_VASKEY=
MOOLRE_SMS_API_KEY=
MOOLRE_SMS_SENDER_ID=
SMS_SENDER_ID=
MOOLRE_SMS_ORDER_NOTIFICATIONS=1
MOOLRE_SMS_SCENARIO_KEY=

# Optional legacy payment providers
PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_SECRET_HASH=
